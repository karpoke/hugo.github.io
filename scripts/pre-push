#!/bin/bash
# Pre-push hook to check if a newer Hugo version is available
# This hook runs before each push and warns if an update is available

echo "🔍 Pre-push hook: Checking Hugo version..."

# Verify Hugo is installed
if ! command -v hugo &> /dev/null; then
    echo "❌ Error: Hugo is not installed"
    exit 1
fi

# Get current installed version
CURRENT_VERSION=$(hugo version 2>/dev/null | grep -oP 'v\K[0-9]+\.[0-9]+\.[0-9]+' | head -1)
if [ -z "$CURRENT_VERSION" ]; then
    echo "⚠️  Warning: Could not determine current Hugo version. Skipping check."
    exit 0
fi

echo "   Installed version: v${CURRENT_VERSION}"

# Get latest release from GitHub API
LATEST_VERSION=$(curl -s --max-time 5 https://api.github.com/repos/gohugoio/hugo/releases/latest \
    | grep -oP '"tag_name":\s*"v\K[0-9]+\.[0-9]+\.[0-9]+' | head -1)

if [ -z "$LATEST_VERSION" ]; then
    echo "⚠️  Warning: Could not fetch latest Hugo version (no internet?). Skipping check."
    exit 0
fi

echo "   Latest version:    v${LATEST_VERSION}"

if [ "$CURRENT_VERSION" = "$LATEST_VERSION" ]; then
    echo "✅ Hugo is up to date (v${CURRENT_VERSION})"
else
    echo ""
    echo "⚠️  A new Hugo version is available: v${LATEST_VERSION} (installed: v${CURRENT_VERSION})"
    echo "   Update: https://github.com/gohugoio/hugo/releases/tag/v${LATEST_VERSION}"
    echo "   Remember to also update HUGO_VERSION in .github/workflows/hugo.yml"
    echo ""
    echo "   Push continues. Update Hugo when convenient."
fi

exit 0

