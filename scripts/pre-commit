#!/bin/bash
# Pre-commit hook to validate the Hugo build
# This hook runs before each commit to ensure the site can be generated

echo "🔍 Pre-commit hook: Validating Hugo build..."

# Verify Hugo is installed
if ! command -v hugo &> /dev/null; then
    echo "❌ Error: Hugo is not installed"
    echo "   Install Hugo from: https://gohugo.io/installation/"
    exit 1
fi

# Run hugo build to validate
if hugo --quiet --minify 2>&1 | tee /tmp/hugo-build.log; then
    echo "✅ Hugo build successful"
    # Clean up generated files (we don't want to commit them)
    rm -rf public/ resources/
    exit 0
else
    echo "❌ Error: Hugo build failed"
    echo ""
    echo "Errors found:"
    cat /tmp/hugo-build.log
    echo ""
    echo "Please fix the errors before committing."
    echo "You can run 'hugo --verbose' for more details."
    exit 1
fi
